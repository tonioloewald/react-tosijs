{
  "name": "react-tosijs",
  "version": "1.2.0",
  "description": "Incredibly simple, powerful, and efficient state management for React…",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "default": "./dist/index.js"
  },
  "files": [
    "/dist",
    "/LICENSE",
    "/README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "start": "bun dev.ts",
    "build": "bun dev.ts --build",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit -p tsconfig.typecheck.json",
    "prepublishOnly": "bun test && bun run typecheck && bun run build"
  },
  "keywords": [
    "react",
    "state-management",
    "hooks",
    "javascript",
    "typescript"
  ],
  "author": "Tonio Loewald",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tonioloewald/react-tosijs.git"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.0",
    "@types/node": "^22.19.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "bun-types": "latest",
    "chokidar": "^4.0.3",
    "eslint": "^8.57.1",
    "happy-dom": "^20.0.0",
    "prettier": "^2.8.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-tosijs": "file:.",
    "tjs-lang": "^0.11.0",
    "tosijs": "^1.6.10",
    "tosijs-ui": "^1.6.23",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "tosijs": "^1.0.6"
  }
}
