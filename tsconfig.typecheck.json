{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    // happy-dom's .d.ts trips on node:stream/web under this TS version;
    // its types are not what this gate checks
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
